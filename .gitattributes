# Normalize line endings at the boundary; working copies stay platform-native
# where it matters. Set BEFORE the first commit so history starts clean.
* text=auto

*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.csv   text
*.bat   text eol=crlf

*.xlsx  binary
*.docx  binary
